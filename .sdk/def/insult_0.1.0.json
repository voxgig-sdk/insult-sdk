              "enum": [
                "txt",
                "json",
                "html"
              ]
            }
          },
          {
            "name": "lang",
            "in": "query",
            "description": "Language for the adjective",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "en",
