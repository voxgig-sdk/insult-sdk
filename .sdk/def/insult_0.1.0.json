            "description": "If present (with who), changes the template to third person plural",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with insult in requested format",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "string"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/InsultSuccessResponse"
                }
              },
              "text/html": {
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "400": {
            "description": "Bad request due to incorrect parameters",
            "content": {
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/InsultErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/adjective": {
      "get": {
        "summary": "Generate a single adjective in plain text",
        "description": "Generates a single adjective in plain text format.",
        "operationId": "getAdjectivePlainText",
        "parameters": [
          {
            "name": "lang",
            "in": "query",
            "description": "Language for the adjective",
