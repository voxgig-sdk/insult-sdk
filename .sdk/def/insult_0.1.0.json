  },
  "components": {
    "schemas": {
      "InsultSuccessResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "boolean",
            "example": false,
            "description": "Indicates if an error occurred"
          },
          "insult": {
            "type": "string",
            "example": "You are as stupid as a bag of rocks",
            "description": "The generated insult string"
          },
          "args": {
            "type": "object",
            "description": "A dictionary listing the parameters used to generate the output, including default values",
            "additionalProperties": true
          }
        },
        "required": [
          "error",
          "insult",
          "args"
        ]
      },
      "AdjectiveSuccessResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "boolean",
            "example": false,
            "description": "Indicates if an error occurred"
          },
          "adjective": {
            "type": "string",
            "example": "stupid",
            "description": "The generated adjective string"
          },
          "args": {
            "type": "object",
            "description": "A dictionary listing the parameters used to generate the output, including default values",
            "additionalProperties": true
          }
        },
        "required": [
          "error",
          "adjective",
          "args"
        ]
      },
      "InsultErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "boolean",
            "example": true,
            "description": "Indicates if an error occurred"
          },
          "error_message": {
            "type": "string",
            "example": "Invalid parameter provided",
            "description": "A brief message describing the reason for the error"
          }
        },
        "required": [
          "error",
          "error_message"
        ]
      }
    }
  }
