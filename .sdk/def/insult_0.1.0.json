            "schema": {
              "type": "string",
              "enum": [
                "en",
                "en_corporate"
              ]
            }
          },
          {
            "name": "format",
            "in": "path",
            "description": "Output format",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "txt",
                "json",
                "html"
              ]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with adjective in requested format",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "string"
                }
              },
              "text/json": {
